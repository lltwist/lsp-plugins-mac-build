+@implementation LSPDisplayTimerProxy
+- (instancetype)initWithDisplay:(lsp::ws::cocoa::CocoaDisplay *)display
+{
+    self = [super init];
+    if (self)
+        _display = display;
+    return self;
+}
+- (void)invalidate
+{
+    _display = NULL;
+}
+- (void)tick:(NSTimer *)timer
