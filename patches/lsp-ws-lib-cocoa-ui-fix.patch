diff --git a/src/main/cocoa/CocoaDisplay.mm b/src/main/cocoa/CocoaDisplay.mm
index c136abb..9dd0bbc 100644
--- a/src/main/cocoa/CocoaDisplay.mm
+++ b/src/main/cocoa/CocoaDisplay.mm
@@ -210,6 +210,31 @@
                 const nswindow_t nsWindow = nswindow_t { [nsevent window] };
                 CocoaWindow *target = find_window(nsWindow);
 
+                // Embedded case: nsevent's window is the host's (Ableton), not ours.
+                // Locate our CocoaWindow by matching the hit-test view to a known pCocoaView.
+                if (!target)
+                {
+                    NSView *root = [nsWindow.window contentView];
+                    NSPoint p = [nsevent locationInWindow];
+                    NSView *hit = [root hitTest:p];
+                    for (size_t i = 0, n = vWindows.size(); i < n && !target; ++i)
+                    {
+                        CocoaWindow *w = vWindows.uget(i);
+                        if (!w || !w->pCocoaView)
+                            continue;
+                        NSView *v = hit;
+                        while (v != nil)
+                        {
+                            if (v == w->pCocoaView)
+                            {
+                                target = w;
+                                break;
+                            }
+                            v = [v superview];
+                        }
+                    }
+                }
+
                 if (!target)
                     return;
                 
